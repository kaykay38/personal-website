---
import Nav from '../components/Nav';
import '../styles/global.css';

interface Props {
  title?: string;
  contentClass?: string;
}

const { title = 'Mia Hunt', contentClass = '' } = Astro.props;
const pageContentClass = ['page-content', contentClass].filter(Boolean).join(' ');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <div class="page-shell">
      <Nav client:load />
      <main class={pageContentClass}>
        <slot />
      </main>
    </div>
  </body>
</html>
