---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/formatDate';
import { siteData } from '../data/site';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Writing">
  <section>
    <h1 class="page-title">Writing</h1>
    <p class="page-subtitle">
      {siteData.writing.subtitle}
    </p>
    <p class="page-sub-subtitle">
      {siteData.writing.subSubtitle}
    </p>

    <ul class="post-list">
      {posts.map((post) => {
        const slug = post.id.replace(/\.mdx?$/, '');

        return (
          <li class="post-list-item">
            <a href={`/writing/${slug}`} class="post-list-title">
              {post.data.title}
            </a>
            <p class="post-list-date">
              {formatDate(post.data.date)}
            </p>
            {post.data.description && (
              <p class="post-list-description">{post.data.description}</p>
            )}
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>
